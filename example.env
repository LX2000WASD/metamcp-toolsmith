###############################################################################
# Toolsmith MCP Server - 示例环境变量
#
# 用法：
#   1) cp example.env .env
#   2) docker compose up -d --build
###############################################################################

# 监听地址（docker 内一般用 0.0.0.0）
TOOLSMITH_HOST=0.0.0.0

# 监听端口
TOOLSMITH_PORT=7071

# 可选：挂载到反向代理下时用（例如 /toolsmith），默认空
TOOLSMITH_BASE_PATH=

# 工具目录（建议使用容器内路径 + volume 挂载）
TOOLSMITH_TOOLS_DIR=/data/tools

# 可选：HTTP 接入鉴权（MetaMCP 可配置 bearerToken => Authorization: Bearer xxx）
TOOLSMITH_BEARER_TOKEN=change-me-to-a-long-random-string

# 可选：写入保护（启用后 create/update/delete 必须传 writeToken）
TOOLSMITH_WRITE_TOKEN=change-me-to-a-long-random-string

# 会话过期时间（毫秒）；0 表示不自动清理（不推荐）
TOOLSMITH_SESSION_TTL_MS=600000


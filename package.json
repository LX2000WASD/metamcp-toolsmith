{
  "name": "toolsmith-mcp-server",
  "version": "0.1.0",
  "description": "Toolsmith MCP Server: build local MCP tools via chat; expose SSE + Streamable HTTP transports for easy MetaMCP integration.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/http.ts",
    "dev:stdio": "tsx watch src/stdio.ts",
    "build": "tsup",
    "start": "node dist/http.js",
    "start:stdio": "node dist/stdio.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.16.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}

